# Copy to .env and fill in. Generate secrets with: openssl rand -hex 32
DB_PASSWORD=change-me
SESSION_SECRET=change-me
COLLAB_SECRET=change-me

# Port published on the host
APP_PORT=8080
# External URL of the app (used for OIDC redirect URIs)
PUBLIC_URL=http://localhost:8080

# Optional: generic OIDC single sign-on (Keycloak, Authentik, Google, ...)
# Redirect URI to register with your IdP: ${PUBLIC_URL}/api/auth/oidc/callback
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPES=openid profile email

# Optional: restrict who can sign up. Comma/space separated; each entry is a
# domain (ics.red) or an exact address (me@ics.red). Empty = anyone may sign up.
SIGNUP_ALLOWLIST=

# Optional: email verification for local signups. Configure SMTP (e.g. Amazon
# SES SMTP credentials) and new local accounts must confirm their email before
# they can sign in. Leave SMTP_HOST empty to disable verification.
# REQUIRE_EMAIL_VERIFICATION can force (true) or disable (false); default is
# "on when SMTP is configured".
REQUIRE_EMAIL_VERIFICATION=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=TypstPad
