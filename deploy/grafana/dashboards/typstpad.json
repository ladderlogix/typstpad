{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["typstpad"],
  "title": "TypstPad",
  "uid": "typstpad-main",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Users",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "typstpad_users" }],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2, "type": "stat", "title": "Projects",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "typstpad_projects" }],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3, "type": "stat", "title": "Documents",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "typstpad_documents" }],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4, "type": "stat", "title": "Active sessions",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "typstpad_active_sessions" }],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5, "type": "timeseries", "title": "Request rate (req/s) by route",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "sum(rate(typstpad_http_requests_total[5m])) by (route)", "legendFormat": "{{route}}" }],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "reqps" } }
    },
    {
      "id": 6, "type": "timeseries", "title": "Request latency p95 (s) by route",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "histogram_quantile(0.95, sum(rate(typstpad_http_request_duration_seconds_bucket[5m])) by (le, route))", "legendFormat": "{{route}}" }],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 5 }, "unit": "s" } }
    },
    {
      "id": 7, "type": "timeseries", "title": "HTTP errors (5xx req/s)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "sum(rate(typstpad_http_requests_total{status=~\"5..\"}[5m]))", "legendFormat": "5xx" }],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 20 }, "unit": "reqps", "color": { "mode": "fixed", "fixedColor": "red" } } }
    },
    {
      "id": 8, "type": "timeseries", "title": "Compiles/s by result",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "sum(rate(typstpad_compile_total[5m])) by (result)", "legendFormat": "{{result}}" }],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 15 }, "unit": "ops" } }
    },
    {
      "id": 9, "type": "timeseries", "title": "Compile duration p95 (s)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "histogram_quantile(0.95, sum(rate(typstpad_compile_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95" }],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 5 }, "unit": "s" } }
    },
    {
      "id": 10, "type": "timeseries", "title": "Goroutines",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "go_goroutines", "legendFormat": "goroutines" }],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 5 } } }
    },
    {
      "id": 11, "type": "timeseries", "title": "Heap in use",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "go_memstats_heap_inuse_bytes", "legendFormat": "heap" }],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "bytes" } }
    }
  ]
}
